{
  "openapi": "3.0.3",
  "info": {
    "title": "xRag API",
    "version": "0.2.0",
    "description": "Phase 1A API persistence baseline"
  },
  "servers": [
    {
      "url": "http://localhost:3001"
    }
  ],
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": [
          "health"
        ],
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Health status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/health/ready": {
      "get": {
        "tags": [
          "health"
        ],
        "operationId": "getReadiness",
        "responses": {
          "200": {
            "description": "Readiness status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/documents": {
      "get": {
        "tags": [
          "documents"
        ],
        "operationId": "listDocuments",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "source_type",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/SourceType"
            }
          },
          {
            "name": "parse_status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tags",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date_from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "date_to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/documents/text": {
      "post": {
        "tags": [
          "documents"
        ],
        "operationId": "createTextDocument",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTextDocumentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateTextDocumentResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/documents/{documentId}": {
      "get": {
        "tags": [
          "documents"
        ],
        "operationId": "getDocument",
        "parameters": [
          {
            "name": "documentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentDetail"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/documents/{documentId}/tags": {
      "patch": {
        "tags": [
          "documents"
        ],
        "operationId": "updateDocumentTags",
        "parameters": [
          {
            "name": "documentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDocumentTagsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated document detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentDetail"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/documents/{documentId}/retry": {
      "post": {
        "tags": [
          "documents"
        ],
        "operationId": "retryDocument",
        "parameters": [
          {
            "name": "documentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Retry job created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RetryDocumentResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/uploads/initiate": {
      "post": {
        "tags": [
          "uploads"
        ],
        "operationId": "initiateUpload",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UploadInitiateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Upload session created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadInitiateResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/uploads/{uploadId}/complete": {
      "post": {
        "tags": [
          "uploads"
        ],
        "operationId": "completeUpload",
        "parameters": [
          {
            "name": "uploadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UploadCompleteRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Upload completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadCompleteResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/tags": {
      "get": {
        "tags": [
          "tags"
        ],
        "operationId": "listTags",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/TagStatus"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tag list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TagListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "tags"
        ],
        "operationId": "createTag",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTagRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tag created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TagItem"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{jobId}": {
      "get": {
        "tags": [
          "jobs"
        ],
        "operationId": "getJob",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobStatusResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ParseStatus": {
        "type": "string",
        "enum": [
          "pending",
          "processing",
          "success",
          "failed"
        ]
      },
      "SourceType": {
        "type": "string",
        "enum": [
          "text",
          "file",
          "link"
        ]
      },
      "SourceOrigin": {
        "type": "string",
        "enum": [
          "manual_input",
          "upload",
          "link"
        ]
      },
      "TagStatus": {
        "type": "string",
        "enum": [
          "active",
          "archived"
        ]
      },
      "JobStatus": {
        "type": "string",
        "enum": [
          "queued",
          "running",
          "succeeded",
          "failed",
          "dead"
        ]
      },
      "DocumentJobType": {
        "type": "string",
        "enum": [
          "parse_document",
          "reparse_document",
          "refresh_search_projection"
        ]
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "ReadinessResponse": {
        "type": "object",
        "required": [
          "status",
          "checks"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "checks": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "DocumentSummary": {
        "type": "object",
        "required": [
          "id",
          "title",
          "content_preview",
          "tags",
          "source_type",
          "source_origin",
          "file_name",
          "parse_status",
          "imported_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "content_preview": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_type": {
            "$ref": "#/components/schemas/SourceType"
          },
          "source_origin": {
            "$ref": "#/components/schemas/SourceOrigin"
          },
          "file_name": {
            "type": "string",
            "nullable": true
          },
          "parse_status": {
            "$ref": "#/components/schemas/ParseStatus"
          },
          "imported_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DocumentDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/DocumentSummary"
          },
          {
            "type": "object",
            "required": [
              "content_raw",
              "content_clean",
              "source_url",
              "mime_type",
              "parse_error_message",
              "created_at"
            ],
            "properties": {
              "content_raw": {
                "type": "string",
                "nullable": true
              },
              "content_clean": {
                "type": "string",
                "nullable": true
              },
              "source_url": {
                "type": "string",
                "nullable": true
              },
              "mime_type": {
                "type": "string",
                "nullable": true
              },
              "parse_error_message": {
                "type": "string",
                "nullable": true
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        ]
      },
      "DocumentListResponse": {
        "type": "object",
        "required": [
          "items",
          "page",
          "page_size",
          "total"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentSummary"
            }
          },
          "page": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "CreateTextDocumentRequest": {
        "type": "object",
        "required": [
          "title",
          "content",
          "tags"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CreateTextDocumentResponse": {
        "type": "object",
        "required": [
          "id",
          "parse_status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "parse_status": {
            "$ref": "#/components/schemas/ParseStatus"
          }
        }
      },
      "UpdateDocumentTagsRequest": {
        "type": "object",
        "required": [
          "tags"
        ],
        "properties": {
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "RetryDocumentResponse": {
        "type": "object",
        "required": [
          "document_id",
          "job_id",
          "parse_status"
        ],
        "properties": {
          "document_id": {
            "type": "string",
            "format": "uuid"
          },
          "job_id": {
            "type": "string",
            "format": "uuid"
          },
          "parse_status": {
            "$ref": "#/components/schemas/ParseStatus"
          }
        }
      },
      "UploadInitiateRequest": {
        "type": "object",
        "required": [
          "file_name",
          "mime_type",
          "file_size"
        ],
        "properties": {
          "file_name": {
            "type": "string"
          },
          "mime_type": {
            "type": "string"
          },
          "file_size": {
            "type": "integer"
          }
        }
      },
      "UploadInitiateResponse": {
        "type": "object",
        "required": [
          "upload_id",
          "object_key",
          "upload_method",
          "upload_url",
          "headers",
          "expires_in"
        ],
        "properties": {
          "upload_id": {
            "type": "string",
            "format": "uuid"
          },
          "object_key": {
            "type": "string"
          },
          "upload_method": {
            "type": "string",
            "enum": [
              "presigned_put"
            ]
          },
          "upload_url": {
            "type": "string"
          },
          "headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "expires_in": {
            "type": "integer"
          }
        }
      },
      "UploadCompleteRequest": {
        "type": "object",
        "required": [
          "title",
          "tags",
          "checksum_sha256"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "checksum_sha256": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          }
        }
      },
      "UploadCompleteResponse": {
        "type": "object",
        "required": [
          "document_id",
          "job_id",
          "parse_status"
        ],
        "properties": {
          "document_id": {
            "type": "string",
            "format": "uuid"
          },
          "job_id": {
            "type": "string",
            "format": "uuid"
          },
          "parse_status": {
            "$ref": "#/components/schemas/ParseStatus"
          }
        }
      },
      "CreateTagRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "TagItem": {
        "type": "object",
        "required": [
          "id",
          "name",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/TagStatus"
          }
        }
      },
      "TagListResponse": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagItem"
            }
          }
        }
      },
      "JobStatusResponse": {
        "type": "object",
        "required": [
          "id",
          "document_id",
          "job_type",
          "status",
          "attempt",
          "error_message"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "document_id": {
            "type": "string",
            "format": "uuid"
          },
          "job_type": {
            "$ref": "#/components/schemas/DocumentJobType"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "attempt": {
            "type": "integer"
          },
          "error_message": {
            "type": "string",
            "nullable": true
          }
        }
      }
    }
  }
}