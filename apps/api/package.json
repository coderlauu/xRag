{
  "name": "@xrag/api",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.integration.json",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate:compiled": "node dist/apps/api/src/database/migrate.js",
    "db:migrate": "tsx src/database/migrate.ts",
    "dev": "nodemon --watch src --ext ts --exec \"node --loader ts-node/esm src/main.ts\"",
    "lint": "tsc --noEmit -p tsconfig.json",
    "openapi:generate": "tsx src/openapi.ts",
    "recovery:scan-storage": "tsx src/recovery/scan-storage-recovery.ts",
    "start": "node dist/apps/api/src/main.js",
    "test": "pnpm test:integration",
    "test:integration": "pnpm build:test && node --test --test-concurrency=1 dist-integration/apps/api/test/integration/*.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@aws-sdk/s3-request-presigner": "^3.1021.0",
    "@aws-sdk/util-format-url": "^3.972.8",
    "@fastify/cors": "^10.0.2",
    "@nestjs/common": "^11.0.11",
    "@nestjs/core": "^11.0.11",
    "@nestjs/platform-fastify": "^11.0.11",
    "@nestjs/swagger": "^11.0.6",
    "@xrag/shared-types": "workspace:*",
    "bullmq": "^5.43.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.6.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.14",
    "pdf-parse": "^2.4.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
