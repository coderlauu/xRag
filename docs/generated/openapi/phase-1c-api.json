  "info": {
    "title": "xRag API",
    "description": "Phase 1C API contract",
    "version": "0.4.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "http://localhost:3001"
    }
  ],
  "components": {
    "schemas": {
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "ReadinessResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "checks": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "required": [
          "status",
          "checks"
        ]
      },
      "OpsHealthServiceDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "healthy",
              "warning",
              "critical"
            ]
          },
          "detail": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "status",
          "detail"
        ]
      },
      "OpsHealthSummaryResponseDto": {
        "type": "object",
        "properties": {
          "services": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OpsHealthServiceDto"
            }
          },
          "generated_at": {
            "type": "string"
          }
        },
        "required": [
          "services",
          "generated_at"
        ]
      },
      "OpsIncidentSummaryDto": {
        "type": "object",
        "properties": {
          "incident_ref": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": [
              "upload",
              "parse",
              "ocr",
              "fetch",
              "projection",
              "deploy",
              "ci"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "tracked",
              "resolved"
            ]
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "external_url": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "incident_ref",
          "source",
          "severity",
          "status",
          "title",
          "summary"
        ]
      },
      "OpsIncidentListResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OpsIncidentSummaryDto"
            }
          }
        },
        "required": [
          "items"
        ]
      },
      "LatestDeploymentResponseDto": {
        "type": "object",
        "properties": {
          "current_image_tag": {
            "type": "string",
            "nullable": true
          },
          "previous_stable_image_tag": {
            "type": "string",
            "nullable": true
          },
          "last_smoke_status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "unknown"
            ]
          },
          "last_smoke_at": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "last_smoke_status"
        ]
      },
      "JobStatusResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "document_id": {
            "type": "string"
          },
          "job_type": {
            "type": "string",
            "enum": [
              "parse_document",
              "reparse_document",
              "refresh_search_projection",
              "run_ocr",
              "fetch_link",
              "rebuild_search_projection"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "running",
              "succeeded",
              "failed",
              "dead"
            ]
          },
          "attempt": {
            "type": "number"
          },
          "error_message": {
            "type": "string",
            "nullable": true
          },
          "diagnosis_code": {
            "type": "string",
            "enum": [
              "storage_presign_failed",
              "multipart_part_failed",
              "upload_complete_invalid_parts",
              "object_missing_on_complete",
              "pdf_parse_runtime_error",
              "pdf_parse_unsupported",
              "pdf_parse_timeout",
              "pdf_parse_empty_text",
              "queue_backlog",
              "ocr_runtime_error",
              "ocr_timeout",
              "ocr_no_text_detected",
              "link_fetch_timeout",
              "link_fetch_blocked",
              "link_extract_empty",
              "link_invalid_url",
              "search_projection_stale"
            ],
            "nullable": true
          },
          "incident_ref": {
            "type": "string",
            "nullable": true
          },
          "runtime_ms": {
            "type": "number",
            "nullable": true
          }
        },
        "required": [
          "id",
          "document_id",
          "job_type",
          "status",
          "attempt"
        ]
      },
      "UploadInitiateRequestDto": {
        "type": "object",
        "properties": {
          "file_name": {
            "type": "string"
          },
          "mime_type": {
            "type": "string"
          },
          "file_size": {
            "type": "number"
          },
          "checksum_sha256": {
            "type": "string"
          }
        },
        "required": [
          "file_name",
          "mime_type",
          "file_size"
        ]
      },
      "UploadInitiateResponseDto": {
        "type": "object",
        "properties": {
          "upload_id": {
            "type": "string"
          },
          "upload_mode": {
            "type": "string",
            "enum": [
              "single",
              "multipart"
            ]
          },
          "object_key": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "initiated",
              "uploading",
              "verifying",
              "uploaded",
              "failed",
              "expired"
            ]
          },
          "upload_method": {
            "type": "string",
            "enum": [
              "presigned_put"
            ]
          },
          "upload_url": {
            "type": "string"
          },
          "headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "part_size_bytes": {
            "type": "number"
          },
          "part_count": {
            "type": "number"
          },
          "provider_upload_id": {
            "type": "string",
            "nullable": true
          },
          "expires_in": {
            "type": "number"
          }
        },
        "required": [
          "upload_id",
          "upload_mode",
          "object_key",
          "status",
          "expires_in"
        ]
      },
      "UploadPartUrlRequestDto": {
        "type": "object",
        "properties": {
          "part_numbers": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        },
        "required": [
          "part_numbers"
        ]
      },
      "UploadPartUrlItemDto": {
        "type": "object",
        "properties": {
          "part_number": {
            "type": "number"
          },
          "upload_url": {
            "type": "string"
          },
          "headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "required": [
          "part_number",
          "upload_url",
          "headers"
        ]
      },
      "UploadPartUrlResponseDto": {
        "type": "object",
        "properties": {
          "upload_id": {
            "type": "string"
          },
          "parts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UploadPartUrlItemDto"
            }
          }
        },
        "required": [
          "upload_id",
          "parts"
        ]
      },
      "UploadPartCompleteRequestDto": {
        "type": "object",
        "properties": {
          "etag": {
            "type": "string"
          },
          "size_bytes": {
            "type": "number"
          }
        },
        "required": [
          "etag",
          "size_bytes"
        ]
      },
      "UploadPartCompleteResponseDto": {
        "type": "object",
        "properties": {
          "upload_id": {
            "type": "string"
          },
          "part_number": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": [
              "initiated",
              "uploaded",
